GEMINI_API_KEY=replace-with-your-gemini-key
GEMINI_MODEL=gemini-flash-latest
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=3600
JOB_TTL_SECONDS=600
ALLOW_FAKE_LLM=false
LOG_LEVEL=INFO
OTEL_ENABLED=true
OTEL_SERVICE_NAME=accessible-travel-assistant
OTEL_ENVIRONMENT=local
# Optional: set this to an OpenTelemetry collector/vendor OTLP HTTP base URL.
# Example: https://otel-collector.example.com
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional comma-separated headers. Example: Authorization=Bearer token,x-api-key=key
OTEL_EXPORTER_OTLP_HEADERS=
